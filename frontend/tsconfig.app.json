{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",

    "ignoreDeprecations": "6.0",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,

    "noEmit": true,

    "skipLibCheck": true,

    "allowImportingTsExtensions": true,

    "verbatimModuleSyntax": true,

    "moduleDetection": "force",

    "types": ["vite/client"]
  },

  "include": ["src"]
}