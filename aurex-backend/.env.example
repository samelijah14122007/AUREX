# Copy these values into the PowerShell terminal before starting the backend.
# This file deliberately contains no real password or production secret.
$env:DB_URL="jdbc:postgresql://localhost:5433/aurex"
$env:DB_USERNAME="aurex_app"
$env:DB_PASSWORD="CHANGE_ME"
$env:JWT_SECRET="replace-with-a-long-random-secret-of-at-least-32-characters"

# Optional: local Ollama model enrichment. AUREX works without Ollama.
$env:OLLAMA_BASE_URL="http://localhost:11434"
$env:OLLAMA_MODEL="llama3.2"
$env:OLLAMA_REQUIRED="true"
$env:AI_PROVIDER="ollama"

# Persistent storage location outside the deployed application directory.
$env:APP_STORAGE_DIRECTORY="uploads"
$env:MAX_UPLOAD_SIZE="20MB"
